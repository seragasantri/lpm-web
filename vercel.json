{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/berita/:path*",
      "destination": "/api/og/:path*"
    }
  ],
  "headers": [
    {
      "source": "/og-default.svg",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, immutable" }
      ]
    }
  ]
}
